# Leave DATABASE_URL unset for local SQLite development.
# Use PostgreSQL in production or when your local Postgres server is running:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_notes_generator
JWT_SECRET_KEY=replace-with-a-secure-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
